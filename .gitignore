# ──────────────────────────────────────────────
# AWS credentials — NEVER commit real keys!
# ──────────────────────────────────────────────
config/aws_credentials.json
credentials/

# ──────────────────────────────────────────────
# Large YOLO model weights (download on-demand)
# ──────────────────────────────────────────────
*.pt
*.pth
*.onnx

# ──────────────────────────────────────────────
# Pipeline output & temporary S3 downloads
# ──────────────────────────────────────────────
output/
output/tmp_s3/

# ──────────────────────────────────────────────
# Python caches
# ──────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/

# ──────────────────────────────────────────────
# Local video files (never commit raw footage)
# ──────────────────────────────────────────────
cam_1/
cam_2/
*.mp4
*.avi
*.mov
*.mkv

# ──────────────────────────────────────────────
# Misc local files
# ──────────────────────────────────────────────
cookie.txt
debug_*.py
test_*.py

# ──────────────────────────────────────────────
# macOS metadata
# ──────────────────────────────────────────────
.DS_Store

# ──────────────────────────────────────────────
# Logs & debug files
# ──────────────────────────────────────────────
*.log
run_out.txt
validation_run.log
foo.log
